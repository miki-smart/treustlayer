# API server (Express) — default port 3001
PORT=3001

# TrustIdLayer — leave empty for local demo (mock introspection + demo: tokens)
TRUSTID_BASE_URL=
# Register via backend-merged/scripts/seed_oauth_clients.py — example client_id:
TRUSTID_CLIENT_ID=app_7b0b6bb71afb49e4
TRUSTID_CLIENT_SECRET=

# Set to "false" when TRUSTID_BASE_URL is set to call real /auth/introspect
TRUSTID_USE_MOCK=true

TRUSTID_INTROSPECT_TIMEOUT_MS=2000
TRUSTID_CIRCUIT_FAILURE_THRESHOLD=5
TRUSTID_CIRCUIT_OPEN_SECONDS=30

# Must match the redirect URI registered for your app (used by Login → token exchange)
TRUSTID_REDIRECT_URI=http://localhost:8080/auth/callback

# Webhook HMAC — optional in dev; required in production
TRUSTID_WEBHOOK_SIGNING_SECRET=
