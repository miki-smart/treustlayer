# Next.js app (frontend/). Copy to frontend/.env.local

# TrustIdLayer base (no trailing slash)
TRUSTIDLAYER_BASE_URL=https://trustidlayer.example.com

TRUSTIDLAYER_CLIENT_ID=
TRUSTIDLAYER_CLIENT_SECRET=

# Must match an allowed redirect URI on the registered app (browser OAuth + token exchange)
TRUSTIDLAYER_REDIRECT_URI=http://localhost:3000/auth/callback

# Browser "Sign in with TrustIdLayer": full OAuth2 authorize page URL.
# If unset, defaults to {TRUSTIDLAYER_BASE_URL}/{TRUSTIDLAYER_OAUTH_AUTHORIZE_PATH} (path default: oauth/authorize).
# TRUSTIDLAYER_OAUTH_AUTHORIZE_URL=https://trustidlayer.example.com/oauth/authorize
# TRUSTIDLAYER_OAUTH_AUTHORIZE_PATH=oauth/authorize

# Introspection result TTL (ms), max 60s recommended
TRUSTIDLAYER_INTROSPECT_TTL_MS=60000
TRUSTIDLAYER_TIMEOUT_MS=8000

# Set true for local UI/dev without a real IdP
TRUSTIDLAYER_MOCK=true

# FastAPI lending engine (sibling folder backend/). When unset, Next uses built-in policy-engine only.
# LENDING_API_URL=http://127.0.0.1:8000
# Same value as backend/.env LENDING_API_SECRET
# LENDING_API_SECRET=change-me-in-dev
# LENDING_API_TIMEOUT_MS=8000
