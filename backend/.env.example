# Application
APP_NAME=TrustLayer ID
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trustlayer

# JWT Configuration (RSA Keys)
# Generate keys with: python scripts/generate_keys.py
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Paste your RSA private key here (the script will print it as a string with \n)
JWT_PRIVATE_KEY=

# Paste your RSA public key here
JWT_PUBLIC_KEY=

# OIDC Issuer
ISSUER=trustlayer

# Webhook settings
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60
